{
  "番茄炒蛋": {
    "steps": [
      "1. 鸡蛋打散，加少许盐搅匀",
      "2. 番茄切块备用",
      "3. 热锅凉油，倒入蛋液炒至凝固后盛出",
      "4. 锅中再加少许油，放入番茄块翻炒出汁",
      "5. 加入适量盐和糖调味",
      "6. 倒回鸡蛋，翻炒均匀即可出锅"
    ],
    "ingredients": [
      "番茄",
      "鸡蛋",
      "盐"
    ]
  },
  "南瓜馒头": {
    "steps": [
      "1. 南瓜去皮切片，上锅蒸熟后压成泥",
      "2. 南瓜泥放凉至温热，加入酵母粉搅匀",
      "3. 倒入面粉，边加边搅拌，揉成光滑面团",
      "4. 盖上湿布，温暖处发酵至两倍大",
      "5. 取出面团排气，分成小剂子，揉圆整形",
      "6. 放入蒸笼，二次醒发 15 分钟",
      "7. 大火烧开后转中火蒸 15 分钟，关火焖 3 分钟再揭盖"
    ],
    "ingredients": []
  },
  "红烧牛肉": {
    "steps": [
      "1. 买牛肉",
      "2. 找到老婆"
    ],
    "ingredients": [
      "牛肉",
      "豆瓣酱",
      "糖色油",
      "大葱",
      "香料"
    ]
  },
  "红烧排骨": {
    "steps": [
      "1. 买排骨",
      "2. 找到老婆",
      "3. 等待吃饭"
    ],
    "ingredients": [
      "排骨",
      "豆瓣酱",
      "香料"
    ]
  }
}